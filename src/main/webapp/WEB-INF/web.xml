<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns="http://xmlns.jcp.org/xml/ns/javaee"
	xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
	id="WebApp_ID" version="4.0">
	<display-name>sample-project</display-name>

	<listener>
		<listener-class>dev.sample.ApplicationContextListener</listener-class>
	</listener>

	<servlet>
		<servlet-name>LoginServlet</servlet-name>
		<servlet-class>dev.sample.auth.LoginServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>LoginServlet</servlet-name>
		<url-pattern>/login</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>LoginServlet</servlet-name>
		<url-pattern>/auth/login</url-pattern>
	</servlet-mapping>

	<servlet>
		<servlet-name>LogoutServlet</servlet-name>
		<servlet-class>dev.sample.auth.LogoutServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>LogoutServlet</servlet-name>
		<url-pattern>/logout</url-pattern>
	</servlet-mapping>

	<servlet>
		<servlet-name>ReportPageServlet</servlet-name>
		<servlet-class>dev.sample.report.ReportPageServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>ReportPageServlet</servlet-name>
		<url-pattern>/report</url-pattern>
	</servlet-mapping>

	<!-- Report TOP -->
	<servlet>
		<servlet-name>TopSpendServlet</servlet-name>
		<servlet-class>dev.sample.report.TopSpendServlet</servlet-class>
	</servlet>

	<servlet-mapping>
		<servlet-name>TopSpendServlet</servlet-name>
		<url-pattern>/report/top</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>TopSpendServlet</servlet-name>
		<url-pattern>/report/region</url-pattern>
	</servlet-mapping>

	<!-- Auth Filter 등록 -->
	<filter>
		<filter-name>AuthFilter</filter-name>
		<filter-class>dev.sample.auth.AuthFilter</filter-class>
	</filter>

	<!-- /report/* 요청에만 적용 -->
	<filter-mapping>
		<filter-name>AuthFilter</filter-name>
		<url-pattern>/report</url-pattern>
	</filter-mapping>

	<filter-mapping>
		<filter-name>AuthFilter</filter-name>
		<url-pattern>/report/*</url-pattern>
	</filter-mapping>

	<welcome-file-list>
		<welcome-file>index.html</welcome-file>
		<welcome-file>index.jsp</welcome-file>
		<welcome-file>index.htm</welcome-file>
		<welcome-file>index.xhtml</welcome-file>
		<welcome-file>default.html</welcome-file>
		<welcome-file>default.jsp</welcome-file>
		<welcome-file>default.htm</welcome-file>
		<welcome-file>default.xhtml</welcome-file>
	</welcome-file-list>
</web-app>
